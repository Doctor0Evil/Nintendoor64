{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "N64 PatchSpec",
  "type": "object",
  "required": ["version", "baseRomId", "layoutId", "edits"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "baseRomId": { "type": "string" },
    "layoutId": { "type": "string" },
    "edits": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["kind", "logicalPath", "payloadRef", "encoding"],
            "additionalProperties": false,
            "properties": {
              "kind": { "const": "replaceFile" },
              "logicalPath": { "type": "string" },
              "payloadRef": { "type": "string" },
              "encoding": { "enum": ["Text", "Hex", "Base64"] }
            }
          },
          {
            "type": "object",
            "required": ["kind", "hookKind", "romOffset", "payloadRef", "encoding"],
            "additionalProperties": false,
            "properties": {
              "kind": { "const": "bootHook" },
              "hookKind": { "type": "string" },
              "romOffset": { "type": "integer", "minimum": 0 },
              "payloadRef": { "type": "string" },
              "encoding": { "enum": ["Text", "Hex", "Base64"] }
            }
          },
          {
            "type": "object",
            "required": ["kind", "logicalPath", "jsonPointer", "value"],
            "additionalProperties": false,
            "properties": {
              "kind": { "const": "jsonPatch" },
              "logicalPath": { "type": "string" },
              "jsonPointer": { "type": "string" },
              "value": {}
            }
          },
          {
            "type": "object",
            "required": ["kind", "romOffset", "maxBytes", "payloadRef", "encoding"],
            "additionalProperties": false,
            "properties": {
              "kind": { "const": "rawIntervalPatch" },
              "romOffset": { "type": "integer", "minimum": 0 },
              "maxBytes": { "type": "integer", "minimum": 0 },
              "payloadRef": { "type": "string" },
              "encoding": { "enum": ["Text", "Hex", "Base64"] }
            }
          }
        ]
      }
    },
    "sourceFilePath": { "type": "string" }
  },
  "additionalProperties": false
}
