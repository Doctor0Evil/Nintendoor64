{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gamemode.ai/schemas/wayback-signatures.schema.json",
  "title": "Wayback SignatureFile",
  "description": "Schema for YAML-driven engine detection signatures used by wayback-detect.",
  "type": "object",
  "required": ["version", "signatures"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Signature"
      }
    }
  },
  "$defs": {
    "Signature": {
      "type": "object",
      "required": [
        "id",
        "engine",
        "protocol",
        "priority",
        "kind",
        "offset"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string",
          "minLength": 1,
          "description": "Logical engine identifier, e.g. GameSpy, IPX, Quake3, GoldSrc."
        },
        "protocol": {
          "type": "string",
          "enum": ["udp", "tcp"]
        },
        "priority": {
          "type": "integer",
          "description": "Higher priority signatures win when multiple match."
        },
        "kind": {
          "type": "string",
          "enum": ["substring", "prefix-bytes"]
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "description": "Byte offset within the payload where matching begins."
        },
        "pattern": {
          "type": "string",
          "description": "UTF-8 substring to search for (for kind=substring)."
        },
        "hex": {
          "type": "string",
          "pattern": "^[0-9a-fA-F\\s]+$",
          "description": "Hex-encoded byte sequence (for kind=prefix-bytes). Whitespace is ignored."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "allOf": [
        {
          "anyOf": [
            { "required": ["pattern"] },
            { "required": ["hex"] }
          ]
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
