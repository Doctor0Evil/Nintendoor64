{
  "$id": "https://gamemode.ai/schemas/bond_objectives.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bond Mission Objectives DAG",
  "type": "object",
  "required": ["schema_version", "mission_id", "objectives"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "condition", "pre"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          },
          "failure": {
            "type": "string"
          },
          "pre": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
