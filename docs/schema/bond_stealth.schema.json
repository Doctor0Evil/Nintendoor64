{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BondFPSCore Stealth Parameters",
  "type": "object",
  "required": ["schema_version", "profile_id", "global", "posture_factors", "movement_factors"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "global": {
      "type": "object",
      "required": [
        "base_visibility",
        "d_max",
        "k_decay",
        "t_suspicious",
        "t_alert",
        "light_exponent",
        "move_exponent"
      ],
      "additionalProperties": false,
      "properties": {
        "base_visibility": { "type": "number", "minimum": 0.0, "maximum": 10.0 },
        "d_max":          { "type": "number", "exclusiveMinimum": 0.0, "maximum": 100.0 },
        "k_decay":        { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "t_suspicious":   { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "t_alert":        { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "light_exponent": { "type": "number", "minimum": 1.0, "maximum": 5.0 },
        "move_exponent":  { "type": "number", "minimum": 0.0, "maximum": 5.0 }
      }
    },
    "posture_factors": {
      "type": "object",
      "required": ["standing", "crouch", "prone"],
      "additionalProperties": false,
      "properties": {
        "standing": { "type": "number", "minimum": 0.0, "maximum": 2.0 },
        "crouch":   { "type": "number", "minimum": 0.0, "maximum": 2.0 },
        "prone":    { "type": "number", "minimum": 0.0, "maximum": 2.0 }
      }
    },
    "movement_factors": {
      "type": "object",
      "required": ["still", "walk", "run"],
      "additionalProperties": false,
      "properties": {
        "still": { "type": "number", "minimum": 0.0, "maximum": 2.0 },
        "walk":  { "type": "number", "minimum": 0.0, "maximum": 2.0 },
        "run":   { "type": "number", "minimum": 0.0, "maximum": 2.0 }
      }
    },
    "sound": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
