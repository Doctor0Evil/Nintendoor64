{
  "repo": "Doctor0Evil/Nintendoor64",
  "version": "0.1.0",
  "features": [
    {
      "id": "nintendoor64.rom_layout_oracle",
      "title": "ROM Layout Oracle",
      "description": "Read-only ROM layout oracle for Nintendoor64-era builds that answers \"what lives where\" questions: segments, banks, file systems, RAM mappings, and budget slices, so AI-Chat can target edits without ever touching raw offsets directly.",
      "tags": [
        "Nintendoor64",
        "Starzip",
        "RomLayout",
        "Oracle",
        "ReadOnly",
        "N64",
        "PS1",
        "NES"
      ],
      "systems": [
        "systems.nintendoor64.starzip.layout_oracle",
        "systems.nintendoor64.sonia.featurelayout",
        "systems.knowledgegraph.core"
      ],
      "schemas": [
        "schemas/romlayout.schema.json",
        "schemas/systemnode.schema.json",
        "schemas/featurelayout.schema.json"
      ],
      "examples": [
        "examples/romlayout/banjo_tooie_layout.json",
        "examples/romlayout/goldeneye_layout.json",
        "knowledgegraph/systems.json"
      ]
    },
    {
      "id": "nintendoor64.safe_patch_synthesizer",
      "title": "Safe Patch Synthesizer",
      "description": "Schema-validated patch synthesizer that takes high-level ArtifactSpecs (scripts, tables, state machines) and compiles them into safe patch bundles wired through Starzip or emulator injection, always routed via explicit ROM layout contracts instead of raw hex editing.",
      "tags": [
        "Nintendoor64",
        "Sonia",
        "ArtifactSpec",
        "Patch",
        "SafeEdit",
        "Starzip"
      ],
      "systems": [
        "systems.nintendoor64.sonia",
        "systems.nintendoor64.starzip.patcher",
        "systems.retro.nes.packer.nrom_128"
      ],
      "schemas": [
        "schemas/artifactspec.schema.json",
        "schemas/rompatch.schema.json",
        "schemas/systemnode.schema.json"
      ],
      "examples": [
        "examples/artifactspec/goldeneye_guard_stealth_patch.json",
        "examples/artifactspec/banjo_room_lightmap_patch.json",
        "examples/patchbundle/sample_patch_bundle.json"
      ]
    },
    {
      "id": "nintendoor64.pattern_composer",
      "title": "Design Pattern Composer",
      "description": "Knowledge-graph-backed pattern composer that lets AI-Chat and humans slot reusable gameplay and level design patterns (Bond stealth arenas, hub-and-spoke dungeons, survival horror camera grids) into new projects via typed recipe and parameter schemas.",
      "tags": [
        "Nintendoor64",
        "Patterns",
        "GameDesign",
        "Recipe",
        "SchemaFirst",
        "KnowledgeGraph"
      ],
      "systems": [
        "systems.gamemodeai.patterns.core",
        "systems.nintendoor64.bondfpscore",
        "systems.nintendoor64.caprom.core",
        "systems.nintendoor64.sonia.featurelayout"
      ],
      "schemas": [
        "schemas/gamerecipe.schema.json",
        "schemas/patterntemplate.schema.json",
        "schemas/stealthparams.schema.json",
        "schemas/narrativegraph.schema.json"
      ],
      "examples": [
        "examples/patterns/bond_fps_stealth_arena.json",
        "examples/patterns/resident_style_horror_loop.json",
        "examples/patterns/snes_underworld_platformer.json"
      ]
    },
    {
      "id": "nintendoor64.build_conductor",
      "title": "Retro Build Conductor",
      "description": "Orchestrator surface that wires Sonia, Starzip, retro-CLI, and emulator harnesses into one contract-first build pipeline, so AI-Chat can schedule multi-step NES/SNES/N64/PS1 builds as a single high-level job using knowledge-graph-scoped commands.",
      "tags": [
        "Nintendoor64",
        "Build",
        "Orchestration",
        "CI",
        "RetroCLI",
        "Starzip",
        "Sonia"
      ],
      "systems": [
